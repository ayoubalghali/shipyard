# Copy this file to .env.local and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/shipyard
# Railway: copy from Railway dashboard > Variables
DATABASE_URL=postgresql://user:password@localhost:5432/shipyard

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32

# ── OAuth Providers ───────────────────────────────────────────────────────────
# GitHub: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM APIs ─────────────────────────────────────────────────────────────────
# Claude API: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama runs locally at http://localhost:11434 — no key needed

# ── Stripe (Week 5+) ─────────────────────────────────────────────────────────
# Stripe: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Monitoring (Week 7+) ─────────────────────────────────────────────────────
# Sentry: https://sentry.io/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
